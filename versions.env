# Pinned inputs for the bge-m3.llamafile build.
#
# Trust model: every input is pinned to an exact, content-addressable revision
# and (where downloaded as a binary) verified against a SHA256 recorded here.
# Change a pin -> the artifact changes -> the published checksum changes. A user
# can re-run this build from these pins and reproduce the same llamafile.
#
# Bootstrapping the hashes: on the first run set the SHA256 vars to "" (empty).
# The build prints the real hash of each downloaded binary instead of enforcing
# it. Copy the printed values back here, commit, and every later run enforces.
#
# This file is sourced by scripts/build-llamafile.sh (plain `KEY=value`, no spaces).

# ---- Source-of-truth model weights (converted + quantized in-repo) ----
# Original BAAI/bge-m3 weights. Pin to an exact commit on Hugging Face:
#   https://huggingface.co/BAAI/bge-m3/commits/main  -> copy the full 40-char SHA.
BGE_M3_HF_REPO=BAAI/bge-m3
BGE_M3_HF_REVISION=5617a9f61b028005a4858fdac845db406aefb181

# ---- Conversion / quantization toolchain ----
# llama.cpp provides convert_hf_to_gguf.py and llama-quantize. Pin to a commit
# whose convert script supports XLMRobertaModel (bge-m3's architecture):
#   https://github.com/ggml-org/llama.cpp/commits/master
LLAMA_CPP_REPO=https://github.com/ggml-org/llama.cpp
LLAMA_CPP_COMMIT=683b04cc4ae9b54236e9b7eaccb4af8e0aab9f2a

# Target quantization. Q4_K_M ~ 438 MB; matches the fireSeqSearch default.
QUANT=Q4_K_M

# ---- llamafile runner + packer ----
# Release assets are named llamafile-<VERSION> and zipalign-<VERSION>:
#   https://github.com/Mozilla-Ocho/llamafile/releases
LLAMAFILE_REPO=Mozilla-Ocho/llamafile
LLAMAFILE_VERSION=0.10.3
# Leave empty on first run to print-only; fill to enforce.
LLAMAFILE_SHA256=e6d4041a82ca37cee15aab62e6826d7a61c6a3ea83bca68387958970df250883
ZIPALIGN_SHA256=7eac59c658226027b365d92131babf06341f746fb20c0db33115bbdf5c5c6c4b

# ---- Output ----
OUTPUT_NAME=bge-m3.llamafile
